# Environment
NODE_ENV=development
PORT=3000
# Database
DATABASE_URL=postgres://user:password@localhost:5432/dbname
# Better Auth
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=https://your-backend-url.com
# JWT Tokens
ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_EXPIRES_IN=15m

REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRES_IN=7d
# Email (SMTP)
EMAIL_SENDER_SMTP_USER=your_email@example.com
EMAIL_SENDER_SMTP_PASSWORD=your_email_password_here
EMAIL_SENDER_SMTP_HOST=smtp.example.com
EMAIL_SENDER_SMTP_PORT=587
EMAIL_SENDER_SMTP_FROM="Your App Name <no-reply@example.com>"